# ==============================================================================
# BLDE EDC — UNIVERSITY / INSTITUTE MODE ENVIRONMENT VARIABLES
# ==============================================================================

# Node Environment Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Database Scoping (pg / sqlite)
DATABASE_MODE=pg

# Campus Workstation PostgreSQL Settings
DB_HOST=postgres
DB_PORT=5432
DB_USER=blde_univ_admin
DB_PASSWORD=SecureUnivPassword123!
DB_NAME=blde_edc_db
DB_SSL=false

# Session Parameters (Strict FDA 21 CFR Part 11 expiration limits)
JWT_SECRET=SecretEncryptionKey998!
JWT_EXPIRES_IN=2h

# Upload Directory Mapping
UPLOAD_DIR=/usr/src/app/uploads
MAX_FILE_SIZE_MB=100

# Institutional Attachment Store (MinIO S3 integration parameters)
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=MinioSecurePassword123!
S3_BUCKET=blde-edc-attachments

# Advanced Operations Clinical Switches
ENABLE_AI=true
ENABLE_ORTHANC=true

# SMTP Server Configurations
SMTP_HOST=smtp.univ.edu
SMTP_PORT=587
SMTP_USER=edc-dispatch@univ.edu
SMTP_PASS=univ_secure_password
SMTP_FROM=edc-dispatch@univ.edu
