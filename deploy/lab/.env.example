# ==============================================================================
# BLDE EDC — RESEARCH LAB / DEPARTMENT MODE ENVIRONMENT VARIABLES
# ==============================================================================

# Node Environment Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Database Dialect Selection (pg / sqlite)
DATABASE_MODE=pg

# PostgreSQL Settings (Docker postgres container parameters)
DB_HOST=postgres
DB_PORT=5432
DB_USER=blde_admin
DB_PASSWORD=LabSecurePassword123!
DB_NAME=blde_edc_db
DB_SSL=false

# Security & Sessions
JWT_SECRET=SecretEncryptionKey998!
JWT_EXPIRES_IN=24h

# File Attachments Size Limits
UPLOAD_DIR=/usr/src/app/uploads
MAX_FILE_SIZE_MB=50

# Optional Clinical Feature Toggles
ENABLE_AI=false
ENABLE_ORTHANC=false
STORAGE_PROVIDER=local

# SMTP Email Dispatch Server (Recommended for alerts & user management)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@blde.ac.in
SMTP_PASS=your-google-app-password
SMTP_FROM=noreply@blde.ac.in
