# ==============================================================================
# BLDE EDC — LAPTOP MODE ENVIRONMENT VARIABLES
# ==============================================================================

# Node Environment Configuration
NODE_ENV=production
PORT=3001
HOST=localhost

# Database Dialect Selection (pg / sqlite)
DATABASE_MODE=pg

# SQLite Settings (Used only if DATABASE_MODE=sqlite)
SQLITE_FILE=./db/blde_edc.sqlite

# PostgreSQL Settings (Used if DATABASE_MODE=pg)
DB_HOST=postgres
DB_PORT=5432
DB_USER=blde_admin
DB_PASSWORD=AdminPassword123
DB_NAME=blde_edc_db
DB_SSL=false

# Security & Sessions
JWT_SECRET=SecretEncryptionKey998!
JWT_EXPIRES_IN=8h

# Uploads Configuration
UPLOAD_DIR=/usr/src/app/uploads
MAX_FILE_SIZE_MB=20

# Optional Clinical Feature Toggles
ENABLE_AI=false
ENABLE_ORTHANC=false
STORAGE_PROVIDER=local

# SMTP Email Dispatch Server (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@blde.ac.in
